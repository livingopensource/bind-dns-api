{
  "server": {
    "host": "0.0.0.0",
    "port": 8080
  },
  "bind": {
    "named_conf_path": "/etc/bind/named.conf",
    "zone_directory": "./zones",
    "rndc_path": "/usr/sbin/rndc",
    "rndc_conf_path": "/etc/bind/rndc.conf",
    "default_ttl": 3600,
    "default_refresh": 7200,
    "default_retry": 3600,
    "default_expire": 1209600,
    "default_minimum": 86400
  },
  "logging": {
    "level": "info",
    "format": "json",
    "output_path": "stdout"
  }
}
